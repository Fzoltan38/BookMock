{
  "openapi": "3.0.1",
  "info": {
    "title": "BookStoreApi",
    "version": "1.0"
  },
  "paths": {
    "/api/Book": {
      "get": {
        "tags": [
          "Book"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Book"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BookCreateDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/BookCreateDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/BookCreateDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Book/{id}": {
      "get": {
        "tags": [
          "Book"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BookCreateDto": {
        "required": [
          "author",
          "isbn",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "author": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string"
          },
          "isbn": {
            "maxLength": 20,
            "minLength": 1,
            "type": "string"
          },
          "price": {
            "maximum": 100000,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "publishedYear": {
            "maximum": 2030,
            "minimum": 1000,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  }
}